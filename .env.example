# Secret key for JWT signing (Change this to something random!)
JWT_SECRET=orbital-security-key-777

# Bcrypt hash of the admin password
# Default is 'admin' - generate a new one using scripts/generate-password.js
ADMIN_PASSWORD_HASH="$2b$10$wI8nS.x3V/pW/9/7X.RjGe5W7R5S8K2k9f0m1o2p3q4r5s6t7u8v9"

# Node Environment
NODE_ENV=development
